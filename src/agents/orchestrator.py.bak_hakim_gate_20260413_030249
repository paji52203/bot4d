    async def _run_specialists_parallel(
        self,
        market_data: Dict[str, Any],
        current_price: Optional[float],
    ) -> Dict[str, Dict[str, Any]]:
        """Run 4 specialists concurrently with retries + safe fallback."""
        proposal = self._default_proposal(current_price)

        tasks = {
            "agent_analysis": self._call_agent_with_retry(
                "agent_analysis",
                lambda: self.agent_analysis.analyze(market_data),
            ),
            "agent_core": self._call_agent_with_retry(
                "agent_core",
                lambda: self.agent_core.validate(proposal, market_data.get("analysis", {})),
            ),
            "agent_risk": self._call_agent_with_retry(
                "agent_risk",
                lambda: self.agent_risk.validate(proposal, market_data, current_price),
            ),
            "agent_market_intel": self._call_agent_with_retry(
                "agent_market_intel",
                lambda: self.agent_market_intel.analyze(
                    market_data,
                    market_data.get("trade_history", {}),
                ),
            ),
        }

        names = list(tasks.keys())
        results = await asyncio.gather(*tasks.values(), return_exceptions=True)

        outputs: Dict[str, Dict[str, Any]] = {}
        for name, result in zip(names, results):
            if isinstance(result, Exception):
                self.logger.error("%s gather exception: %s", name, result)
                outputs[name] = dict(self.SAFE_FALLBACK)
            else:
                outputs[name] = result

        return outputs

    async def _call_agent_with_retry(
        self,
        agent_name: str,
        call_fn: Callable[[], Awaitable[Dict[str, Any]]],
        max_retries: int = 2,
    ) -> Dict[str, Any]:
        """
        Call agent and validate JSON output.
        Retry up to 2 times on invalid/failed payload.
        """
        last_error = "unknown_error"

        for attempt in range(max_retries + 1):
            try:
                raw = await call_fn()
                parsed = self._extract_agent_json(raw)
                if isinstance(parsed, dict):
                    return parsed
                last_error = "invalid_json"
            except Exception as exc:
                last_error = str(exc)
                self.logger.warning(
                    "%s failed attempt %s/%s: %s",
                    agent_name,
                    attempt + 1,
                    max_retries + 1,
                    exc,
                )

            if attempt < max_retries:
                await asyncio.sleep(0.2 * (attempt + 1))

        fallback = dict(self.SAFE_FALLBACK)
        fallback["agent"] = agent_name
        fallback["error"] = last_error or "timeout"
        return fallback

    def _normalize_confidence_scale(self, payload: Dict[str, Any]) -> Dict[str, Any]:
        """Normalize confidence fields from 0..1 scale into 0..100 scale."""
        if not isinstance(payload, dict):
            return payload

        def _norm(key: str) -> None:
            if key not in payload:
                return
            try:
                val = float(payload.get(key))
            except Exception:
                return
            if 0 < val <= 1:
                payload[key] = round(val * 100.0, 2)

        _norm('confidence')
        _norm('final_confidence')
        return payload

    def _extract_agent_json(self, raw: Any) -> Optional[Dict[str, Any]]:
        """Normalize different agent return shapes into a JSON dict."""
        if isinstance(raw, dict):
            if raw.get("success") is True and isinstance(raw.get("data"), dict):
                return self._normalize_confidence_scale(raw["data"])
            if "signal" in raw or "error" in raw:
                return self._normalize_confidence_scale(raw)
        return None

    def _extract_hakim_json(self, text: str) -> Optional[Dict[str, Any]]:
        """Extract Hakim final JSON robustly; only accept object containing final_decision."""
        if not text:
            return None

        t = str(text).strip()

        # strip fences
        t = re.sub(r"^```(?:json)?\s*", "", t, flags=re.IGNORECASE)
        t = re.sub(r"\s*```$", "", t)

        # Fast-path strict JSON
        try:
            obj = json.loads(t)
            if isinstance(obj, dict) and 'final_decision' in obj:
                return obj
        except Exception:
            pass

        # Scan ALL JSON objects and pick the LAST one with final_decision
        decoder = json.JSONDecoder()
        i = 0
        best = None
        while i < len(t):
            ch = t[i]
            if ch != '{':
                i += 1
                continue
            try:
                obj, end = decoder.raw_decode(t[i:])
                if isinstance(obj, dict) and 'final_decision' in obj:
                    best = obj
                i += max(end, 1)
            except Exception:
                i += 1

        return best


    def _compile_manager_template(self, reports: Dict[str, Dict[str, Any]]) -> str:
        """Compile specialist outputs into exact manager template string."""
        agent_analysis_json = json.dumps(
            reports.get("agent_analysis", self.SAFE_FALLBACK), ensure_ascii=False
        )
        agent_core_json = json.dumps(
            reports.get("agent_core", self.SAFE_FALLBACK), ensure_ascii=False
        )
        agent_risk_json = json.dumps(
            reports.get("agent_risk", self.SAFE_FALLBACK), ensure_ascii=False
        )
        agent_market_intel_json = json.dumps(
            reports.get("agent_market_intel", self.SAFE_FALLBACK), ensure_ascii=False
        )

        return (
            "[SYSTEM: All agents have submitted their reports. Review the data below and output your final JSON decision.]\n\n"
            "### A. Analysis Agent Output\n"
            f"{agent_analysis_json}\n\n"
            "### B. Core Agent Output\n"
            f"{agent_core_json}\n\n"
            "### C. Risk Agent Output\n"
            f"{agent_risk_json}\n\n"
            "### D. Market Intelligence Agent Output\n"
            f"{agent_market_intel_json}"
        )



    def _derive_hakim_math_params(
        self,
        reports: Dict[str, Dict[str, Any]],
        current_price: Optional[float],
    ) -> Dict[str, float]:
        """Derive immutable math params for Hakim prompt from specialist reports."""
        a = reports.get("agent_analysis", {}) if isinstance(reports, dict) else {}
        b = reports.get("agent_core", {}) if isinstance(reports, dict) else {}
        e = reports.get("agent_risk", {}) if isinstance(reports, dict) else {}

        def _f(v: Any, d: float = 0.0) -> float:
            try:
                return float(v)
            except Exception:
                return float(d)

        cp = _f(current_price, 0.0)
        if cp <= 0:
            cp = _f(a.get("entry"), 0.0) or _f(b.get("entry"), 0.0) or _f(e.get("entry"), 0.0)

        sl = (
            _f(e.get("adjusted_stop_loss"), 0.0)
            or _f(e.get("stop_loss"), 0.0)
            or _f((a.get("key_levels") or {}).get("stop_loss"), 0.0)
            or _f(b.get("stop_loss"), 0.0)
        )
        tp = (
            _f(e.get("adjusted_take_profit"), 0.0)
            or _f(e.get("take_profit"), 0.0)
            or _f(b.get("take_profit"), 0.0)
            or _f(a.get("take_profit"), 0.0)
        )

        if cp <= 0:
            cp = 1.0
        if sl <= 0:
            sl = cp * 0.995
        if tp <= 0:
            tp = cp * 1.005

        risk = abs(cp - sl)
        reward = abs(tp - cp)
        rr = reward / max(risk, 1e-9)

        lev = _f(e.get("leverage"), 0.0)
        if lev <= 0:
            lev = 10.0

        return {
            "current_price": round(cp, 6),
            "sl_math": round(sl, 6),
            "tp_math": round(tp, 6),
            "rr_ratio": round(rr, 4),
            "leverage_math": int(max(1, min(125, round(lev)))),
        }


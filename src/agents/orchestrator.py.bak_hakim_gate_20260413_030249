    def _normalize_manager_decision(
        self,
        manager_json: Dict[str, Any],
        current_price: Optional[float],
    ) -> Dict[str, Any]:
        """Normalize manager output into app-consumable decision schema."""
        src = manager_json or {}
        final_decision = src.get("final_decision", "HOLD")
        signal = str(final_decision).upper().strip()
        if signal not in {"BUY", "SELL", "HOLD"}:
            signal = "HOLD"

        def to_float(value: Any, default: float) -> float:
            try:
                return float(value)
            except Exception:
                return float(default)

        payload = src.get("execution_payload", {}) if isinstance(src.get("execution_payload"), dict) else {}
        consensus = src.get("consensus_report", {}) if isinstance(src.get("consensus_report"), dict) else {}

        position_pct = to_float(payload.get("position_size_pct", src.get("position_size", 0.0)), 0.0)
        if position_pct > 1:
            position_size = max(0.0, min(1.0, position_pct / 100.0))
        else:
            position_size = max(0.0, min(1.0, position_pct))

        decision = {
            "signal": signal,
            "confidence": max(0.0, min(100.0, (to_float(src.get("confidence", src.get("final_confidence", 35)), 35) * 100.0 if 0 < to_float(src.get("confidence", src.get("final_confidence", 35)), 35) <= 1 else to_float(src.get("confidence", src.get("final_confidence", 35)), 35)))),
            "entry": to_float(src.get("entry", payload.get("entry", current_price or 0)), current_price or 0),
            "stop_loss": to_float(src.get("stop_loss", payload.get("stop_loss", 0)), 0),
            "take_profit": to_float(src.get("take_profit", payload.get("take_profit", 0)), 0),
            "position_size": position_size,
            "reasoning": str(src.get("reasoning", consensus.get("logic_summary", "manager_decision"))),
        }
        return decision

